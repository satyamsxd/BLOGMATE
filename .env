# ── Blogy — Provider API Keys ───────────────────────────────────────────
# Add your API keys below. The system will try providers in priority order
# and automatically fall back to the next if one hits its rate limit.

# ── Ollama (LOCAL — UNLIMITED, FREE, NO API KEY) ─────────────────────
# Install: https://ollama.com/download
# Pull model: ollama pull llama3.1:8b (or qwen2.5:7b, mistral, etc.)
# Ollama auto-starts at localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Google Gemini (FREE — 15 RPM, 1M TPM on gemini-2.0-flash)
GEMINI_API_KEY=AIzaSyBVRClJwQ-Wvf6IXU8-s3ZBhrJ3mcb3HdE
GEMINI_MODEL=gemini-2.0-flash

# Groq (FREE — 30 RPM, 14400 RPD on llama-3.3-70b-versatile)
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (PAID — optional, used as fallback)
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-4o-mini

# Grok / xAI (PAID — optional, used as fallback)
GROK_API_KEY=xai-TB2lk6SgPAJgPE8MmIZjvdKUkU83XxtPHhXvrfp2AuTN7e5tU5Kz4voyqCWZr2me4gciUh5sI0XfPydl
GROK_MODEL=grok-3

# ── Provider Priority ──────────────────────────────────────────────────
# Comma-separated. Ollama (local) first for unlimited generation.
# Cloud providers used as fallback only.
PROVIDER_PRIORITY=ollama,groq,gemini,openai,grok

# ── Retry & Throttle Config ───────────────────────────────────────────
PROVIDER_MAX_RETRIES=2
PROVIDER_BACKOFF_BASE=1.0
# Minimum seconds between requests to same provider (prevents rate limiting)
# Lower than before since round-robin distributes calls across providers
PROVIDER_MIN_DELAY=2.5

# ── Security Configuration ────────────────────────────────────────────────
# API key that callers must send as the X-API-Key request header.
# Leave BLANK to disable auth (safe for local dev only).
# In production: set a long random string e.g. openssl rand -hex 32
BLOGMATE_API_KEY=

# Comma-separated list of frontend origins allowed to call the API.
# Local dev: http://localhost:8000
# Production: https://your-blogmate-app.onrender.com
ALLOWED_ORIGINS=http://localhost:8000