# ── Blogmate — Environment Variables Template ───────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets. Only commit .env.example.

# ── Provider API Keys ──────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GROK_API_KEY=
GROK_MODEL=grok-3

# Ollama (local, free, no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Provider Priority ──────────────────────────────────────────────────
PROVIDER_PRIORITY=ollama,groq,gemini,openai,grok

# ── Retry & Throttle Config ───────────────────────────────────────────
PROVIDER_MAX_RETRIES=2
PROVIDER_BACKOFF_BASE=1.0
PROVIDER_MIN_DELAY=2.5

# ── Security Configuration ────────────────────────────────────────────
# API key clients must send as the X-API-Key header.
# Leave blank to disable auth (local dev only).
# Generate a strong key: openssl rand -hex 32
BLOGMATE_API_KEY=

# Comma-separated allowed frontend origins for CORS.
# Local: http://localhost:8000
# Production: https://your-app.onrender.com
ALLOWED_ORIGINS=http://localhost:8000
